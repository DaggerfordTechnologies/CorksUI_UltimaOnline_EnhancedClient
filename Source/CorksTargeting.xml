<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../Interface.xsd">
	<Windows>
		<Window name="CorksTargetingWindow" movable="true" layer="popup">
			<Size>
				<AbsPoint x="280" y="460" />
			</Size>
			<Anchors>
				<Anchor point="center" relativePoint="center">
					<AbsPoint x="0" y="0" />
				</Anchor>
			</Anchors>
			<EventHandlers>
				<EventHandler event="OnInitialize" function="CorksTargeting.Initialize" />
				<EventHandler event="OnShutdown" function="CorksTargeting.Shutdown" />
				<EventHandler event="OnRButtonUp" function="CorksTargeting.OnClose" />
				<EventHandler event="OnMouseWheel" function="WindowUtils.Scale" />
			</EventHandlers>
			<Windows>
				<Window name="$parentChrome" inherits="UO_DefaultWindow">
					<Anchors>
						<Anchor point="topleft" relativePoint="topleft" />
						<Anchor point="bottomright" relativePoint="bottomright" />
					</Anchors>
				</Window>
				<Window name="CorksTargetingWindowContent">
					<Size>
						<AbsPoint x="250" y="400" />
					</Size>
					<Anchors>
						<Anchor point="top" relativePoint="top">
							<AbsPoint x="0" y="40" />
						</Anchor>
					</Anchors>
					<Windows>
						<FullResizeImage name="$parentBackground" inherits="UO_Simple_Black_Background">
							<Anchors>
								<Anchor point="topleft" relativePoint="topleft">
									<AbsPoint x="-5" y="-5" />
								</Anchor>
								<Anchor point="bottomright" relativePoint="bottomright">
									<AbsPoint x="5" y="5" />
								</Anchor>
							</Anchors>
						</FullResizeImage>
						<FullResizeImage name="$parentFrame" inherits="UO_Default_Inner_Window_Frame">
							<Anchors>
								<Anchor point="topleft" relativePoint="topleft">
									<AbsPoint x="-5" y="-5" />
								</Anchor>
								<Anchor point="bottomright" relativePoint="bottomright">
									<AbsPoint x="5" y="5" />
								</Anchor>
							</Anchors>
						</FullResizeImage>
						<Window name="CorksTargetingWindowScrollChild">
							<Size>
								<AbsPoint x="230" y="350" />
							</Size>
						</Window>
					</Windows>
				</Window>
			</Windows>
		</Window>
	</Windows>
</Interface>
